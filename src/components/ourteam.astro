    <h2 class="text-balance mb-[2.5rem] text-5xl md:text-6xl font-['Mona_Sans'] font-bold">Nuestro <span class="text-[#0071eb]">Equipo</span></h2>
    
    
    <div class="grid grid-cols-1 lg:grid-cols-2 xl:grid-cols-3 gap-4 mb-4">
        <TeamCard 
            name="Joel Huamani Estefanero" 
