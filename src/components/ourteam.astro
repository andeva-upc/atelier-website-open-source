    <div class="grid grid-cols-1 lg:grid-cols-2 xl:grid-cols-1  gap-4">
        <div class="w-full">
            <VideoCard 
                client:load 
                youtubeUrl="https://www.youtube.com/embed/QGMqat4oA00?si=A2d-jfye9Rov0CmL" 
