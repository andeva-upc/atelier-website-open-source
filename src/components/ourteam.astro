---
import TeamCard from './react/TeamCard'
import VideoCard from './react/VideoCard'
---

<section class="md:section py-8 px-5 flex flex-col justify-center w-full max-w-7xl ml-auto mr-auto">
    <h2 class="reveal-left text-balance mb-[2.5rem] text-5xl md:text-6xl font-['Mona_Sans'] font-bold" data-i18n="ourteam.title">Nuestro <span class="text-[#0071eb]">Equipo</span></h2>
    
    
    <div class="flex flex-wrap justify-center gap-4 mb-4">
        <div class="reveal w-full lg:w-[calc((100%-1rem)/2)] xl:w-[calc((100%-2rem)/3)]">
            <TeamCard 
                name="Joel Huamani Estefanero" 
                role="" 
                username="shouydev" 
                avatar="/images/Joel.webp"
                quoteBefore="Estudiante de la Universidad Peruana de Ciencias Aplicadas de la carrera de Ingeniería de Software. "
                quoteHighlight="Especializado en liderar y controlar"
                quoteAfter=" el flujo del proyecto."
                highlightColor="blue"
                client:load
            />
        </div>
        <div class="reveal delay-100 w-full lg:w-[calc((100%-1rem)/2)] xl:w-[calc((100%-2rem)/3)]">
            <TeamCard 
                name="Adiel Abdiaz Sanchez Santin" 
                role="" 
                username="xs4el" 
                avatar="/images/Adiel.webp"
                quoteBefore="Estudiante de la Universidad Peruana de Ciencias Aplicadas de la carrera de Ingeniería de Software. "
                quoteHighlight="Especializado en Front-End"
                quoteAfter="."
                highlightColor="blue"
                client:load
            />
        </div>
        <div class="reveal delay-200 w-full lg:w-[calc((100%-1rem)/2)] xl:w-[calc((100%-2rem)/3)]">
            <TeamCard 
                name="Aldo Jeanfranco Machacca Soto" 
                role="" 
                username="AldoDev20" 
                avatar="/images/Aldo.webp"
                quoteBefore="Estudiante de la Universidad Peruana de Ciencias Aplicadas de la carrera de Ingeniería de Software. "
                quoteHighlight="Especializado en Web Services"
                quoteAfter=" y desarrollo Back-End."
                highlightColor="blue"
                client:load
            />
        </div>
        <div class="reveal delay-300 w-full lg:w-[calc((100%-1rem)/2)] xl:w-[calc((100%-2rem)/3)]">
            <TeamCard 
                name="Jennifer Yamilet Riveros Vera" 
                role="" 
                username="Jennivz" 
                avatar="/images/Jennifer.webp"
                quoteBefore="Estudiante de la Universidad Peruana de Ciencias Aplicadas de la carrera de Ingeniería de Software. "
                quoteHighlight="Especializada en datos"
                quoteAfter="."
                highlightColor="blue"
                client:load
            />
        </div>
        <div class="reveal delay-400 w-full lg:w-[calc((100%-1rem)/2)] xl:w-[calc((100%-2rem)/3)]">
            <TeamCard 
                name="Luis Daniel Granda Ibarra" 
                role="" 
                username="danieltyuyu" 
                avatar="/images/Daniel.webp"
                quoteBefore="Estudiante de la Universidad Peruana de Ciencias Aplicadas cursando la carrera de Ingeniería de Software. "
                quoteHighlight="Especializado en los datos"
                quoteAfter=" y visualización del proyecto."
                highlightColor="blue"
                client:load
            />
        </div>
    </div>
    
    <div class="grid grid-cols-1 lg:grid-cols-2 xl:grid-cols-1  gap-4">
        <div class="reveal-left w-full">
            <VideoCard 
                client:load 
                youtubeUrl="https://youtu.be/SzdJd2aiv1A" 
                label="@Video-About-The-Team"
                quoteBefore="«En Atelier, creemos que la tecnología no debería ser complicada. "
                quoteHighlight="Nuestra misión es empoderar a los talleres mecánicos"
                quoteAfter="con herramientas inteligentes y automatizadas de última generación»."
            />
        </div>
    
        <div class="reveal-right w-full">
            <div class="border border-black bg-white flex flex-col p-6 md:p-8 rounded-none h-full justify-center">
                <div class="w-full aspect-video border border-dashed border-zinc-300 bg-zinc-50 flex flex-col items-center justify-center text-zinc-400 p-4">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 mb-2 opacity-60 text-[#0071eb]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5l4.72-4.72a.75.75 0 011.28.53v11.38a.75.75 0 01-1.28.53l-4.72-4.72M4.5 18.75h9a2.25 2.25 0 002.25-2.25v-9a2.25 2.25 0 00-2.25-2.25h-9A2.25 2.25 0 002.25 7.5v9a2.25 2.25 0 002.25 2.25z" />
                    </svg>
                    <span class="font-['Arimo'] font-semibold text-zinc-600 text-sm md:text-base">Video del producto (Próximamente)</span>
                    <span class="font-['Arimo'] text-zinc-400 text-xs mt-1 text-center">Un recorrido completo por las funcionalidades de Atelier</span>
                </div>
                <div class="w-full text-end mt-6">
                    <span class="bg-[#B3D4F8] px-1 py-0.5 mx-0.5 font-semibold text-lg text-black">
                        @Video-About-The-Product
                    </span>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    @media (min-width: 768px) {
        .md\:section {
            display: flex;
            width: 100%;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding-left: 1.25rem;
            padding-right: 1.25rem;
        }
    }
</style>