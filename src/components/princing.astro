---
// Componente de Precios de Atelier
---

<section id="pricing" class="py-16 md:py-24 bg-[#fff] border-t border-gray-100/50 overflow-hidden">
  <div class="container mx-auto px-4 max-w-7xl">
    
    <!-- Encabezado de la Sección -->
    <div class="text-center max-w-2xl mx-auto mb-16 md:mb-20">
      <h2 class="reveal font-['Mona_Sans'] text-4xl md:text-5xl font-extrabold text-[#212121] leading-tight tracking-tight text-pretty" data-i18n="pricing.title">
        Planes creados a su <span class="text-[#0071eb]">medida</span>
      </h2>
      <p class="reveal delay-100 font-['Arimo'] text-gray-500 text-lg md:text-xl mt-4" data-i18n="pricing.subtitle">
        Elige el plan ideal para automatizar, controlar y escalar la rentabilidad de tu taller.
      </p>
    </div>

    <!-- Carrusel de Precios / Grilla -->
    <div class="relative w-full">
      <!-- El contenedor del carrusel tiene snap scroll en mobile/tablet y se convierte en grilla en desktop (lg) -->
      <div 
        id="pricing-carousel" 
        class="flex lg:grid lg:grid-cols-3 gap-6 md:gap-8 overflow-x-auto lg:overflow-x-visible snap-x snap-mandatory scroll-smooth pb-8 px-4 -mx-4 lg:px-0 lg:mx-0 scrollbar-none"
      >
        
        <!-- ================= CARD 1: LITE ================= -->
        <div class="reveal snap-center shrink-0 w-[88vw] sm:w-[50vw] md:w-[45vw] lg:w-full flex flex-col justify-between bg-white border border-gray-200/80 rounded-[20px] p-6 md:p-8 shadow-sm hover:shadow-md transition-all duration-300 flex-grow min-h-[620px]">
          
          <!-- Top Content -->
          <div class="mb-8">
            <h3 class="font-['Mona_Sans'] text-3xl font-extrabold text-[#212121] text-center" data-i18n="pricing.lite.title">Lite</h3>
            <p class="font-['Arimo'] text-gray-500 text-sm mt-2 min-h-[40px] leading-relaxed text-center" data-i18n="pricing.lite.subtitle">
              Conoce y explora el uso de atelier
            </p>
            
            <!-- Price Layout (Styled after Image 1) -->
            <div class="flex items-baseline gap-2 mt-6 font-['Mona_Sans'] justify-center">
              <span class="text-xl font-bold text-[#212121] self-start mt-1">S/.</span>
              <span class="text-6xl font-black tracking-tight text-[#212121]">99</span>
              <div class="flex flex-col ml-1">
                <span class="text-xs font-semibold text-gray-500 mt-0.5" data-i18n="pricing.perMonth">/ mes</span>
              </div>
            </div>
          </div>

          <!-- Feature Container (Light Blue Styled Box from Image 2) -->
          <div class="bg-[#B3D4F8]/35 rounded-[20px] p-5 md:p-6 flex-grow flex flex-col justify-between">
            <div>
              <span class="block font-['Mona_Sans'] text-xs font-extrabold text-[#0071eb] uppercase tracking-wider mb-4" data-i18n="pricing.lite.includes">
                Incluye:
              </span>
              <ul class="space-y-4 font-['Arimo'] text-[#212121] text-sm md:text-base">
                <li class="flex items-start gap-3">
                  <div class="shrink-0 mt-0.5">
                    <!-- Blue Checkmark Circle Icon -->
                    <svg class="w-5 h-5 text-[#0071eb]" viewBox="0 0 20 20" fill="currentColor">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
                    </svg>
                  </div>
                  <span class="font-medium text-gray-800" data-i18n="pricing.lite.feat1">Gestión básica ERP</span>
                </li>
                <li class="flex items-start gap-3">
                  <div class="shrink-0 mt-0.5">
                    <svg class="w-5 h-5 text-[#0071eb]" viewBox="0 0 20 20" fill="currentColor">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
                    </svg>
                  </div>
                  <span class="font-medium text-gray-800" data-i18n="pricing.lite.feat2">Inventario</span>
                </li>
                <li class="flex items-start gap-3">
                  <div class="shrink-0 mt-0.5">
                    <svg class="w-5 h-5 text-[#0071eb]" viewBox="0 0 20 20" fill="currentColor">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
                    </svg>
                  </div>
                  <span class="font-medium text-gray-800" data-i18n="pricing.lite.feat3">Conexión de hasta 5 vehículos</span>
                </li>
                <li class="flex items-start gap-3">
                  <div class="shrink-0 mt-0.5">
                    <svg class="w-5 h-5 text-[#0071eb]" viewBox="0 0 20 20" fill="currentColor">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
                    </svg>
                  </div>
                  <span class="font-medium text-gray-800" data-i18n="pricing.lite.feat4">Próximas funciones</span>
                </li>
              </ul>
            </div>

            <!-- Full-Width Premium Button -->
            <button class="w-full mt-8 font-['Arimo'] font-semibold py-3 px-6 rounded-md border border-[#0071eb] text-[#0071eb] bg-white hover:bg-[#0071eb] hover:text-white transition-all duration-300 hover:scale-[1.02] active:scale-[0.98] cursor-pointer" data-i18n="pricing.lite.cta">
              Seleccionar Lite
            </button>
          </div>

        </div>

        <!-- ================= CARD 2: PRO (HIGHLIGHTED) ================= -->
        <div class="reveal delay-150 snap-center shrink-0 w-[88vw] sm:w-[50vw] md:w-[45vw] lg:w-full flex flex-col justify-between bg-[#0071eb] rounded-[20px] p-6 md:p-8 shadow-xl relative overflow-hidden flex-grow min-h-[620px] transform lg:-translate-y-2 lg:scale-[1.02]">
          

          <!-- Top Content (White on Blue) -->
          <div class="w-full flex flex-col mb-8 justify-center">
            <h3 class="font-['Mona_Sans'] text-3xl font-extrabold text-white text-center" data-i18n="pricing.pro.title">Pro</h3>
            <p class="font-['Arimo'] text-blue-100 text-sm mt-2 min-h-[40px] leading-relaxed text-center" data-i18n="pricing.pro.subtitle">
              Experimenta el poder de infinitas posibilidades
