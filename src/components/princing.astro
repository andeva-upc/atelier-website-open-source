              </div>
            </div>
          </div>

          <!-- Feature Container (White Block from Image 2 for perfect contrast) -->
          <div class="bg-white rounded-[20px] p-5 md:p-6 flex-grow flex flex-col justify-between shadow-inner">
            <div>
              <span class="block font-['Mona_Sans'] text-xs font-extrabold text-[#0071eb] uppercase tracking-wider mb-4" data-i18n="pricing.pro.includes">
