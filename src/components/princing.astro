              <ul class="space-y-4 font-['Arimo'] text-[#212121] text-sm md:text-base">
                <li class="flex items-start gap-3">
                  <div class="shrink-0 mt-0.5">
                    <svg class="w-5 h-5 text-[#0071eb]" viewBox="0 0 20 20" fill="currentColor">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
                    </svg>
                  </div>
                  <span class="font-semibold text-gray-900" data-i18n="pricing.pro.feat1">Todas las funciones del Plan Lite</span>
                </li>
                <li class="flex items-start gap-3">
                  <div class="shrink-0 mt-0.5">
                    <svg class="w-5 h-5 text-[#0071eb]" viewBox="0 0 20 20" fill="currentColor">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
                    </svg>
                  </div>
                  <span class="font-medium text-gray-800" data-i18n="pricing.pro.feat2">Gestión avanzada ERP</span>
                </li>
                <li class="flex items-start gap-3">
                  <div class="shrink-0 mt-0.5">
                    <svg class="w-5 h-5 text-[#0071eb]" viewBox="0 0 20 20" fill="currentColor">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
                    </svg>
                  </div>
                  <span class="font-medium text-gray-800" data-i18n="pricing.pro.feat3">Módulo de facturación electrónica</span>
                </li>
                <li class="flex items-start gap-3">
                  <div class="shrink-0 mt-0.5">
                    <svg class="w-5 h-5 text-[#0071eb]" viewBox="0 0 20 20" fill="currentColor">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
                    </svg>
                  </div>
                  <span class="font-medium text-gray-800" data-i18n="pricing.pro.feat4">Conexión de hasta 20 vehículos</span>
                </li>
              </ul>
            </div>

            <!-- Full-Width Premium Solid Button -->
            <button class="w-full mt-8 font-['Arimo'] font-semibold py-3 px-6 rounded-md bg-[#0071eb] text-white hover:bg-[#0052ad] transition-all duration-300 hover:scale-[1.02] active:scale-[0.98] cursor-pointer shadow-md" data-i18n="pricing.pro.cta">
              Seleccionar Pro
            </button>
          </div>

        </div>

        <!-- ================= CARD 3: MAX ================= -->
        <div class="reveal delay-300 snap-center shrink-0 w-[88vw] sm:w-[50vw] md:w-[45vw] lg:w-full flex flex-col justify-between bg-white border border-gray-200/80 rounded-[20px] p-6 md:p-8 shadow-sm hover:shadow-md transition-all duration-300 flex-grow min-h-[620px]">
          
          <!-- Top Content -->
          <div class="mb-8">
            <h3 class="font-['Mona_Sans'] text-3xl font-extrabold text-[#212121] text-center" data-i18n="pricing.max.title">Max</h3>
            <p class="font-['Arimo'] text-gray-500 text-sm mt-2 min-h-[40px] leading-relaxed text-center" data-i18n="pricing.max.subtitle">
              Desbloquea el máximo rendimiento de atelier
            </p>
            
            <!-- Price Layout (Styled after Image 1) -->
            <div class="flex items-baseline gap-2 mt-6 font-['Mona_Sans'] justify-center">
              <span class="text-xl font-bold text-[#212121] self-start mt-1">S/.</span>
              <span class="text-6xl font-black tracking-tight text-[#212121]">499</span>
              <div class="flex flex-col ml-1">
                <span class="text-xs font-semibold text-gray-500 mt-0.5" data-i18n="pricing.perMonth">/ mes</span>
              </div>
            </div>
          </div>

          <!-- Feature Container (Light Blue Styled Box from Image 2) -->
          <div class="bg-[#B3D4F8]/35 rounded-[20px] p-5 md:p-6 flex-grow flex flex-col justify-between">
            <div>
              <span class="block font-['Mona_Sans'] text-xs font-extrabold text-[#0071eb] uppercase tracking-wider mb-4" data-i18n="pricing.max.includes">
                Todo lo de Pro, más:
              </span>
              <ul class="space-y-4 font-['Arimo'] text-[#212121] text-sm md:text-base">
                <li class="flex items-start gap-3">
                  <div class="shrink-0 mt-0.5">
                    <svg class="w-5 h-5 text-[#0071eb]" viewBox="0 0 20 20" fill="currentColor">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
                    </svg>
                  </div>
                  <span class="font-semibold text-gray-900" data-i18n="pricing.max.feat1">Todas las funciones del Plan Pro</span>
                </li>
                <li class="flex items-start gap-3">
                  <div class="shrink-0 mt-0.5">
                    <svg class="w-5 h-5 text-[#0071eb]" viewBox="0 0 20 20" fill="currentColor">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
                    </svg>
                  </div>
                  <span class="font-medium text-gray-800" data-i18n="pricing.max.feat2">Reportes de rentabilidad</span>
                </li>
                <li class="flex items-start gap-3">
                  <div class="shrink-0 mt-0.5">
                    <svg class="w-5 h-5 text-[#0071eb]" viewBox="0 0 20 20" fill="currentColor">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
                    </svg>
                  </div>
                  <span class="font-medium text-gray-800" data-i18n="pricing.max.feat3">Conexión de hasta 50 vehículos</span>
                </li>
                <li class="flex items-start gap-3">
                  <div class="shrink-0 mt-0.5">
                    <svg class="w-5 h-5 text-[#0071eb]" viewBox="0 0 20 20" fill="currentColor">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
                    </svg>
                  </div>
                  <span class="font-medium text-gray-800" data-i18n="pricing.max.feat4">Automatizaciones</span>
                </li>
              </ul>
            </div>

            <!-- Full-Width Premium Button -->
            <button class="w-full mt-8 font-['Arimo'] font-semibold py-3 px-6 rounded-md border border-[#0071eb] text-[#0071eb] bg-white hover:bg-[#0071eb] hover:text-white transition-all duration-300 hover:scale-[1.02] active:scale-[0.98] cursor-pointer" data-i18n="pricing.max.cta">
              Seleccionar Max
            </button>
          </div>

        </div>

      </div>

      <!-- Carousel Progress Indicator Dots (Visible on mobile/tablet, hidden on lg desktop) -->
      <div class="flex justify-center items-center gap-2 mt-4 lg:hidden">
        <button class="pricing-dot w-6 h-2 rounded-full bg-[#0071eb] transition-all duration-300" data-i18n="[aria-label]pricing.lite.dotsLabel" aria-label="Ver plan Lite"></button>
        <button class="pricing-dot w-2 h-2 rounded-full bg-gray-300 transition-all duration-300" data-i18n="[aria-label]pricing.pro.dotsLabel" aria-label="Ver plan Pro"></button>
        <button class="pricing-dot w-2 h-2 rounded-full bg-gray-300 transition-all duration-300" data-i18n="[aria-label]pricing.max.dotsLabel" aria-label="Ver plan Max"></button>
      </div>

    </div>

  </div>
</section>

<!-- Inline CSS to hide scrollbar while keeping functionality native and smooth -->
<style>
  /* Custom scrollbar utility classes */
  .scrollbar-none::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-none {
    -ms-overflow-style: none;  /* IE and Edge */
    scrollbar-width: none;  /* Firefox */
  }
</style>

<!-- Vanilla JS to sync swipe scroll position with progress dots -->
<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const carousel = document.getElementById('pricing-carousel');
    const dots = document.querySelectorAll('.pricing-dot');
    
    if (carousel && dots.length > 0) {
      const gap = 24; 
      
      const scrollToPro = () => {
        if (window.innerWidth < 1024) {
          const cardWidth = carousel.firstElementChild.getBoundingClientRect().width;
          carousel.scrollLeft = 1 * (cardWidth + gap);
          
          dots.forEach((dot, idx) => {
            if (idx === 1) {
              dot.classList.add('bg-[#0071eb]', 'w-6');
              dot.classList.remove('bg-gray-300', 'w-2');
            } else {
              dot.classList.add('bg-gray-300', 'w-2');
              dot.classList.remove('bg-[#0071eb]', 'w-6');
            }
          });
        }
      };

      // Scroll to Pro card on load (small timeout ensures layout has settled)
      setTimeout(scrollToPro, 100);

      carousel.addEventListener('scroll', () => {
        const scrollLeft = carousel.scrollLeft;
        const cardWidth = carousel.firstElementChild.getBoundingClientRect().width;
        const index = Math.round(scrollLeft / (cardWidth + gap));
        
        dots.forEach((dot, idx) => {
          if (idx === index) {
            dot.classList.add('bg-[#0071eb]', 'w-6');
            dot.classList.remove('bg-gray-300', 'w-2');
          } else {
            dot.classList.add('bg-gray-300', 'w-2');
            dot.classList.remove('bg-[#0071eb]', 'w-6');
          }
        });
      });

      // Allow tapping dots to slide to that card
      dots.forEach((dot, idx) => {
        dot.addEventListener('click', () => {
          const cardWidth = carousel.firstElementChild.getBoundingClientRect().width;
          carousel.scrollTo({
            left: idx * (cardWidth + gap),
            behavior: 'smooth'
          });
        });
      });

      // Handle window resize to re-center active or Pro card
      let resizeTimeout;
      window.addEventListener('resize', () => {
        clearTimeout(resizeTimeout);
        resizeTimeout = setTimeout(() => {
          if (window.innerWidth < 1024) {
            const activeDotIndex = Array.from(dots).findIndex(dot => dot.classList.contains('bg-[#0071eb]'));
            const targetIndex = activeDotIndex >= 0 ? activeDotIndex : 1;
            const cardWidth = carousel.firstElementChild.getBoundingClientRect().width;
            carousel.scrollLeft = targetIndex * (cardWidth + gap);
          }
        }, 150);
      });
    }
  });
</script>
