					"footer.terms": "Terms & conditions",
					"footer.privacy": "Privacy policy",
					"pricing.title": "Plans tailored to your <span class=\"text-[#0071eb]\">needs</span>",
					"pricing.subtitle": "Choose the perfect plan to automate, control, and scale your workshop's profitability.",
