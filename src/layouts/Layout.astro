---
import Header from '../components/header.astro'
import Footer from '../components/footer.astro'
import LanguageSelector from '../components/react/LanguageSelector'
---


<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" href="/nut-color-primary.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>Atelier</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Arimo:ital,wght@0,400..700;1,400..700&family=Mona+Sans:ital,wght@0,200..900;1,200..900&display=swap" rel="stylesheet">
	</head>
	<body>
		<Header />
		<main id="main-content" transition:animate="fade" class="pt-20 md:pt-10">
			<slot />
		</main>
		<Footer />
		<LanguageSelector client:load />
		<script is:inline>
			const translations = {
				es: {
					"nav.access": "Acceder",
					"nav.start": "Comience ahora",
					"nav.startMobile": "Comenzar",
					"hero.title": "Transformar tu <span class=\"text-[#0071eb]\">taller</span>",
					"hero.subtitle": "Optimiza tu taller y prevén fallas con telemetría en tiempo real, todo en un solo lugar.",
					"hero.cta": "Únete al cambio",
					"hero.loginLabel": "¿Ya tienes una cuenta?",
					"hero.loginLink": "Iniciar Sesion",
					"ourteam.title": "Nuestro <span class=\"text-[#0071eb]\">Equipo</span>",
					"footer.connect": "Conectar",
					"footer.legal": "Legal",
					"footer.terms": "Términos y condiciones",
					"footer.privacy": "Política de privacidad"
				},
				en: {
					"nav.access": "Log in",
					"nav.start": "Get started",
					"nav.startMobile": "Get started",
					"hero.title": "Transform your <span class=\"text-[#0071eb]\">workshop</span>",
					"hero.subtitle": "Optimize your workshop and prevent failures with real-time telemetry, all in one place.",
					"hero.cta": "Join the change",
					"hero.loginLabel": "Already have an account?",
					"hero.loginLink": "Log in",
					"ourteam.title": "Our <span class=\"text-[#0071eb]\">Team</span>",
					"footer.connect": "Connect",
					"footer.legal": "Legal",
					"footer.terms": "Terms & conditions",
					"footer.privacy": "Privacy policy"
				}
			};

			function applyTranslations(lang) {
				document.querySelectorAll('[data-i18n]').forEach(el => {
					const key = el.getAttribute('data-i18n');
					if (translations[lang] && translations[lang][key]) {
						el.innerHTML = translations[lang][key];
					}
				});
				document.documentElement.lang = lang;
			}

			// Apply stored language on load
			document.addEventListener('DOMContentLoaded', () => {
				const activeLang = localStorage.getItem('atelier-lang') || 'es';
				applyTranslations(activeLang);
			});

			// Listen to languagechange event
			window.addEventListener('languagechange', (e) => {
				applyTranslations(e.detail.lang);
			});
		</script>
	</body>
</html>

<style>
	html, body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
	main {
		background-color: white;
	}
</style>
