					"pricing.pro.title": "Pro",
					"pricing.pro.subtitle": "Experimenta el poder de infinitas posibilidades",
					"pricing.pro.includes": "Todo lo de Lite, más:",
					"pricing.pro.feat1": "Todas las funciones del Plan Lite",
					"pricing.pro.feat2": "Gestión avanzada ERP",
					"pricing.pro.feat3": "Módulo de facturación electrónica",
					"pricing.pro.feat4": "Conexión de hasta 20 vehículos",
					"pricing.pro.cta": "Seleccionar Pro",
