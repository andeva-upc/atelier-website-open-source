				en: {
					"nav.access": "Log in",
					"nav.start": "Get started",
					"nav.startMobile": "Get started",
					"hero.title": "Transform your <span class=\"text-[#0071eb]\">workshop</span>",
					"hero.subtitle": "Optimize your workshop and prevent failures with real-time telemetry, all in one place.",
