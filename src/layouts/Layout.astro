					"pricing.lite.feat4": "Upcoming features",
					"pricing.lite.cta": "Select Lite",
					"pricing.pro.title": "Pro",
					"pricing.pro.subtitle": "Experience the power of infinite possibilities",
					"pricing.pro.includes": "Everything in Lite, plus:",
					"pricing.pro.feat1": "All features from Lite Plan",
					"pricing.pro.feat2": "Advanced ERP management",
					"pricing.pro.feat3": "Electronic invoicing module",
					"pricing.pro.feat4": "Connection for up to 20 vehicles",
					"pricing.pro.cta": "Select Pro",
					"pricing.max.title": "Max",
					"pricing.max.subtitle": "Unlock the maximum performance of atelier",
					"pricing.max.includes": "Everything in Pro, plus:",
					"pricing.max.feat1": "All features from Pro Plan",
					"pricing.max.feat2": "Profitability reports",
					"pricing.max.feat3": "Connection for up to 50 vehicles",
					"pricing.max.feat4": "Automations",
					"pricing.max.cta": "Select Max",
					"pricing.perMonth": "/ month",
					"pricing.lite.dotsLabel": "View Lite plan",
					"pricing.pro.dotsLabel": "View Pro plan",
					"pricing.max.dotsLabel": "View Max plan"
				}
			};

			function applyTranslations(lang) {
				document.querySelectorAll('[data-i18n]').forEach(el => {
					const key = el.getAttribute('data-i18n');
					if (translations[lang] && translations[lang][key]) {
						el.innerHTML = translations[lang][key];
					}
				});
				document.documentElement.lang = lang;
			}

			// Apply stored language & init Scroll Reveal on load
			document.addEventListener('DOMContentLoaded', () => {
				const activeLang = localStorage.getItem('atelier-lang') || 'en';
				applyTranslations(activeLang);

				// Initialize Scroll Reveal Observer
				const observerOptions = {
					root: null,
					rootMargin: '0px 0px -8% 0px',
					threshold: 0.08
				};

				const observer = new IntersectionObserver((entries, obs) => {
					entries.forEach(entry => {
						if (entry.isIntersecting) {
							entry.target.classList.add('active');
							obs.unobserve(entry.target);
						}
					});
				}, observerOptions);

				const revealElements = document.querySelectorAll('.reveal, .reveal-left, .reveal-right, .reveal-scale');
				revealElements.forEach(el => observer.observe(el));
			});

			// Listen to languagechange event
			window.addEventListener('languagechange', (e) => {
				applyTranslations(e.detail.lang);
			});
		</script>
	</body>
</html>

<style>
	html, body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
	main {
		background-color: white;
	}
</style>
